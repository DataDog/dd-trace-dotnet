{
  "title": ".NET OTLP Runtime Metrics",
  "description": "OTel-native .NET runtime metrics dashboard using dotnet.* metric names sent via OTLP.\nCovers System.Runtime instruments from .NET 9+ (native) and .NET 6-8 (polyfill).\n\nClone this template dashboard to make changes and add your own graph widgets.",
  "widgets": [
    {
      "id": 1000000000000001,
      "definition": {
        "title": "CPU Time (rate)",
        "show_legend": true,
        "legend_layout": "auto",
        "type": "timeseries",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "metrics",
                "name": "cpu_user",
                "query": "avg:dotnet.process.cpu.time{cpu.mode:user,$env,$service,$host}"
              }
            ],
            "formulas": [
              { "formula": "per_second(cpu_user)", "alias": "User CPU (s/s)" }
            ],
            "style": { "palette": "dog_classic", "line_type": "solid", "line_width": "normal" },
            "display_type": "line"
          },
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "metrics",
                "name": "cpu_sys",
                "query": "avg:dotnet.process.cpu.time{cpu.mode:system,$env,$service,$host}"
              }
            ],
            "formulas": [
              { "formula": "per_second(cpu_sys)", "alias": "System CPU (s/s)" }
            ],
            "style": { "palette": "dog_classic", "line_type": "solid", "line_width": "normal" },
            "display_type": "line"
          },
          {
            "on_right_yaxis": true,
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "metrics",
                "name": "cpu_total",
                "query": "avg:dotnet.process.cpu.time{$env,$service,$host}"
              },
              {
                "data_source": "metrics",
                "name": "cpu_count",
                "query": "avg:dotnet.process.cpu.count{$env,$service,$host}"
              }
            ],
            "formulas": [
              { "formula": "per_second(cpu_total) / cpu_count * 100", "alias": "CPU %" }
            ],
            "style": { "palette": "warm", "line_type": "solid", "line_width": "normal" },
            "display_type": "line"
          }
        ],
        "yaxis": { "label": "seconds/second", "include_zero": true, "min": "auto", "max": "auto" },
        "right_yaxis": { "label": "percent", "include_zero": true, "min": "auto", "max": "auto" }
      }
    },
