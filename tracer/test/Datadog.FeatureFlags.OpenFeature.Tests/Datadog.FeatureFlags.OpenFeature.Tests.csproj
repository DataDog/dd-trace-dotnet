<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Target NET8+ because MeterListener (required for these tests) needs NET6+.
         OpenFeature itself supports all frameworks (net462, netstandard2.0, net8.0, net9.0). -->
    <TargetFrameworks>net8.0;net9.0</TargetFrameworks>
    <!-- Disable strong naming since OpenFeature NuGet package is not signed -->
    <SignAssembly>false</SignAssembly>
  </PropertyGroup>

  <ItemGroup>
    <!-- Reference only the OpenFeature project - NOT Datadog.Trace to avoid CS0433 type conflicts -->
    <ProjectReference Include="..\..\src\Datadog.FeatureFlags.OpenFeature\Datadog.FeatureFlags.OpenFeature.csproj" />
  </ItemGroup>

</Project>
