{
  "dsl": "any(filter(ref DictionaryLocal, { @key == 'hello' }), { @value == 'world' })",
  "any": [
    {
      "filter": [
        {
          "ref": "DictionaryLocal"
        },
        {
          "eq": [
            "@key",
            "hello"
          ]
        }
      ]
    },
    {
      "eq": [
        "@value",
        "world"
      ]
    }
  ]
}
