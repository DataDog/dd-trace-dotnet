<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RunAnalyzersDuringBuild>true</RunAnalyzersDuringBuild>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="xunit.runner.json" />
     <None Update="Configuration\HandsOffConfigData\application_monitoring.yml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Configuration\HandsOffConfigData\application_monitoring_fleet.yml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Configuration\HandsOffConfigData\corrupt_file.yml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Configuration\HandsOffConfigData\corrupt_file2.yml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Configuration\HandsOffConfigData\corrupt_file3.yml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Content Include="xunit.runner.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AgileObjects.ReadableExpressions" Version="3.3.0" />
    <PackageReference Include="log4net" Version="2.0.12" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.13.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.2" />
    <PackageReference Include="NLog" Version="4.5.11" />
    <PackageReference Include="Serilog" Version="2.5.0" />
    <PackageReference Include="Serilog.Sinks.Observable" Version="2.0.1" />
    <PackageReference Include="System.Reactive.Core" Version="3.1.1" />
    <PackageReference Include="System.Data.SqlClient" Version="4.8.2" />
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.113.7" />
    <PackageReference Include="Google.Protobuf" Version="3.27.0" />

    <ProjectReference Include="..\..\src\Datadog.Trace.Manual\Datadog.Trace.Manual.csproj" Aliases="DatadogTraceManual" />

    <ProjectReference Include="..\..\src\Datadog.Trace\Datadog.Trace.csproj" />
    <ProjectReference Include="..\..\src\Datadog.Trace.Annotations\Datadog.Trace.Annotations.csproj" />
    <ProjectReference Include="..\..\src\Datadog.Trace.ClrProfiler.Managed.Loader\Datadog.Trace.ClrProfiler.Managed.Loader.csproj" />
    <ProjectReference Include="..\Datadog.Trace.TestHelpers\Datadog.Trace.TestHelpers.csproj" />
  </ItemGroup>

  <ItemGroup Condition=" $(TargetFramework.StartsWith('net4')) ">
    <Reference Include="System.Net.Http" />
    <!-- Used as the customer side of the legacy ASP.NET Core header duck-typing tests. -->
    <PackageReference Include="Microsoft.AspNetCore.Http" Version="2.1.22" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Diagnostics.DiagnosticSource" Version="4.7.0" />
  </ItemGroup>

  <ItemGroup Condition=" !$(TargetFramework.StartsWith('net4')) ">
    <PackageReference Include="System.Net.Http" Version="4.3.4" />
    <PackageReference Include="Microsoft.AspNetCore" Version="2.2.0" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc" Version="2.2.0" />
    <PackageReference Include="Microsoft.AspNetCore.TestHost" Version="2.2.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Datadog.Trace.TestHelpers.SharedSource\VerifyHelper.cs" Link="Helpers\VerifyHelper.cs" />
    <PackageReference Include="Verify.Xunit" Version="14.13.1" />
    <PackageReference Include="DiffPlex" Version="1.7.2" />
  </ItemGroup>

  <ItemGroup>
    <!-- OTLP .proto files vendored from open-telemetry/opentelemetry-proto@v1.10.0. The matching
         C# bindings under OpenTelemetry\Traces\Generated\ are pre-generated and committed so the
         OTLP serializer tests can decode wire bytes via Google.Protobuf parsers without invoking
         protoc at build time (Grpc.Tools does not ship a musl/Alpine binary, and NuGet does not
         preserve the executable bit on Unix). See OpenTelemetry\Traces\Generated\README.md for
         the regeneration command. -->
    <None Include="OpenTelemetry\Traces\proto\**\*.proto" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="FeatureFlags\resources\config\flags-v1.json" />
    <EmbeddedResource Include="FeatureFlags\resources\data\*.json" />
    <None Remove="Telemetry\telemetry_*.json" />
    <EmbeddedResource Include="Telemetry\telemetry_*.json" />
    <None Remove="Telemetry\Metrics\*.json" />
    <EmbeddedResource Include="Telemetry\Metrics\*.json" />
  </ItemGroup>
</Project>
