{
  "version": "2.0",
  "logging": {
    "logLevel": {
      "default": "Trace",
      "Host.*": "Trace",
      "Microsoft.*": "Trace"
    },
    "console": {
      "isEnabled": true
    }
  },
  "extensions": {
    "eventHubs": {
      "maxEventBatchSize": 1,
      "minEventBatchSize": 1,
      "batchCheckpointFrequency": 1
    }
  }
}
