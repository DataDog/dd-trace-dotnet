<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
  <!-- Earliest supported version for MassTransit 8.0.4 -->
    <ApiVersion Condition="'$(ApiVersion)' == ''">8.5.8</ApiVersion>
    <RequiresDockerDependency>All</RequiresDockerDependency>
    <TargetFrameworks>net48;netcoreapp2.1;netcoreapp3.0;netcoreapp3.1;net5.0;net6.0;net7.0;net8.0;net9.0;net10.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MassTransit" Version="$(ApiVersion)" />
    <PackageReference Include="MassTransit.RabbitMQ" Version="$(ApiVersion)" />
    <PackageReference Include="MassTransit.AmazonSQS" Version="$(ApiVersion)" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="8.0.0" />
    <PackageReference Include="OpenTelemetry" Version="1.7.0" />
    <PackageReference Include="OpenTelemetry.Exporter.Console" Version="1.7.0" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.7.0" />
  </ItemGroup>

  <!-- Shared MassTransit sample sources (common Contracts/Consumers/Observer/TestSignal, neutral namespace). -->
  <ItemGroup>
    <Compile Include="..\Samples.MassTransit.Shared\Contracts\GettingStarted.cs" Link="Contracts\GettingStarted.cs" />
    <Compile Include="..\Samples.MassTransit.Shared\Contracts\OrderMessages.cs" Link="Contracts\OrderMessages.cs" />
    <Compile Include="..\Samples.MassTransit.Shared\Consumers\GettingStartedConsumer.cs" Link="Consumers\GettingStartedConsumer.cs" />
    <Compile Include="..\Samples.MassTransit.Shared\Consumers\FailingConsumer.cs" Link="Consumers\FailingConsumer.cs" />
    <Compile Include="..\Samples.MassTransit.Shared\FaultSignalObserver.cs" Link="FaultSignalObserver.cs" />
    <Compile Include="..\Samples.MassTransit.Shared\TestSignal.cs" Link="TestSignal.cs" />
  </ItemGroup>
</Project>
