<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <AssemblyName>Samples.AspNetCoreNetFramework21</AssemblyName>
    <RootNamespace>Samples.AspNetCoreNetFramework</RootNamespace>
    <RequiresDockerDependency>All</RequiresDockerDependency>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="../Samples.AspNetCoreNetFramework/*.cs" Link="%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore" Version="2.1.7" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc" Version="2.1.3" />
    <PackageReference Include="MongoDB.Driver" Version="2.23.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../../../src/Datadog.Trace.Manual/Datadog.Trace.Manual.csproj" />
  </ItemGroup>

</Project>
