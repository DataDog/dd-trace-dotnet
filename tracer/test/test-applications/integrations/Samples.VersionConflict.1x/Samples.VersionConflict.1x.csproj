<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- NU1510: System.Net.Http is flagged as framework-provided, but this sample is named "VersionConflict"
         and intentionally pins legacy versions of Datadog.Trace and System.Net.Http for the regression scenario. -->
    <NoWarn>$(NoWarn);NU1510</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Datadog.Trace" Version="1.29.0" />
    <PackageReference Include="System.Net.Http" Version="4.3.4" />
  </ItemGroup>

  <!-- Required to fix package pruning errors introduced in rc2. Should be removed in NET 10 GA -->
  <PropertyGroup Condition="$(TargetFramework.StartsWith('net4'))">
    <RestoreEnablePackagePruning>false</RestoreEnablePackagePruning>
  </PropertyGroup>

</Project>
