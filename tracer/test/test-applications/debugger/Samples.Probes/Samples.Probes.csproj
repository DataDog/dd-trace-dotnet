<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>

    <!-- NU1510: System.Memory below is flagged as framework-provided on modern TFMs, but it's needed
         on net4x targets where Span<T> comes from the package rather than the BCL. -->
    <NoWarn>$(NoWarn);NU1510</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Memory" Version="4.5.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\dependency-libs\Samples.Probes.TestRuns\Samples.Probes.TestRuns.csproj" />
    <ProjectReference Include="..\dependency-libs\Samples.Probes.Unreferenced.External\Samples.Probes.Unreferenced.External.csproj" />
  </ItemGroup>

</Project>
